---
layout: base.njk
---

<main class="">
  <p class="back">
    <a href="/" onclick="history.length > 1 && (history.back(), event.preventDefault())">
      Back
    </a>
  </p>
  <article class="film_description">
    {% if filmed %}
    <p class="film_description__date">
      <strong>Date:</strong>
      {{filmed}}
    </p>
    {% endif %}
    {% if location %}
    <p class="film_description__location">
      <strong>Location:</strong>
      {{location}}
    </p>
    {% endif %}
    {% if story %}
    <p class="film_description__story">
      <strong>Story:</strong>
      {{story}}
    </p>
    {% endif %}
    {% if camera %}
    <p class="film_description__camera">
      <strong>Camera</strong>:
      {{camera}}
    </p>
    {% endif %}
    {% if lens %}
    <p class="film_description__lens">
      <strong>Lens</strong>:
      {{lens}}
    </p>
    {% endif %}
    {% if film %}
    <p class="film_description__film">
      <strong>Film</strong>:
      {{film}}
    </p>
    {% endif %}
    {% if developing %}
    <p class="film_description__develop">
      <strong>Developing</strong>:
      {{developing}}
    </p>
    {% endif %}
  </article>
  <div class="contacts_container">

    {%- for photo in photos -%}
      <div class="contact">
        <a
          href="/rolls/{{number}}/photos/{{photo.number}}.jpg"
          data-gallery-link
          data-photo-index="{{ loop.index0 }}"
          data-photo-caption="{{ photo.number }}. {{ photo.description | escape }}"
        >
          <img class="contact__image" src="/rolls/{{number}}/photos/xs-{{photo.number}}.jpg" loading="lazy" alt="{{photo.description}}">
        </a>
        <p>
          {{photo.number}}. {{photo.description}}
        </p>
      </div>
    {%- endfor -%}

  </div>

  <div class="lightbox" data-lightbox hidden>
    <button class="lightbox__close" type="button" data-lightbox-close aria-label="Close photo viewer">×</button>
    <button class="lightbox__nav lightbox__nav--prev" type="button" data-lightbox-prev aria-label="Previous photo">←</button>
    <figure class="lightbox__figure">
      <img class="lightbox__image" data-lightbox-image alt="">
      <figcaption class="lightbox__caption" data-lightbox-caption></figcaption>
    </figure>
    <button class="lightbox__nav lightbox__nav--next" type="button" data-lightbox-next aria-label="Next photo">→</button>
  </div>
</main>
